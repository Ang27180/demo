<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" 
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
    xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" 
    name="CertificadoCurso" pageWidth="842" pageHeight="595" orientation="Landscape" 
    columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">

    <parameter name="NOMBRE_ESTUDIANTE" class="java.lang.String"/>
    <parameter name="NOMBRE_CURSO" class="java.lang.String"/>
    <parameter name="FECHA" class="java.lang.String"/>
    <parameter name="LOGO_PATH" class="java.io.InputStream"/>
    <parameter name="FIRMA_PATH" class="java.io.InputStream"/>

    <background>
        <band splitType="Stretch"/>
    </background>

    <title>
        <band height="555" splitType="Stretch">

            <!-- ✅ LOGO COMO MARCA DE AGUA A TAMAÑO COMPLETO (RELLENANDO TODO EL ESPACIO) -->
            <image scaleImage="FillFrame" hAlign="Center" vAlign="Middle">
                <reportElement 
                    x="0" 
                    y="0" 
                    width="802" 
                    height="555"
                    mode="Transparent"/>
                <graphicElement>
                    <pen lineWidth="0.0"/>
                </graphicElement>
                <imageExpression><![CDATA[$P{LOGO_PATH}]]></imageExpression>
            </image>

            <!-- BORDE (MARCADO COMO TRANSPARENTE PARA NO TAPAR EL LOGO) -->
            <rectangle>
                <reportElement x="0" y="0" width="802" height="555" forecolor="#FFC107" mode="Transparent"/>
                <graphicElement>
                    <pen lineWidth="10.0" lineStyle="Double"/>
                </graphicElement>
            </rectangle>

            <!-- TITULO -->
            <staticText>
                <reportElement x="0" y="60" width="802" height="60" forecolor="#000000"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="40" isBold="true" isItalic="true"/>
                </textElement>
                <text><![CDATA[SABOR MASTERCLASS]]></text>
            </staticText>

            <staticText>
                <reportElement x="0" y="140" width="802" height="30"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="18"/>
                </textElement>
                <text><![CDATA[Otorga el presente certificado a:]]></text>
            </staticText>

            <!-- NOMBRE -->
            <textField>
                <reportElement x="0" y="190" width="802" height="50" forecolor="#000000"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="32" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{NOMBRE_ESTUDIANTE}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="270" width="802" height="30"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="18"/>
                </textElement>
                <text><![CDATA[Por haber completado satisfactoriamente el curso de:]]></text>
            </staticText>

            <!-- CURSO -->
            <textField>
                <reportElement x="0" y="320" width="802" height="50" forecolor="#000000"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="28" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{NOMBRE_CURSO}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="410" width="802" height="20"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="14"/>
                </textElement>
                <text><![CDATA[Dado en la ciudad de Bogotá D.C. el día:]]></text>
            </staticText>

            <!-- FECHA -->
            <textField>
                <reportElement x="0" y="440" width="802" height="30"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="16" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{FECHA}]]></textFieldExpression>
            </textField>

            <!-- FIRMA -->
            <image scaleImage="RetainShape">
                <reportElement x="301" y="445" width="200" height="70"/>
                <imageExpression><![CDATA[$P{FIRMA_PATH}]]></imageExpression>
            </image>

            <line>
                <reportElement x="301" y="515" width="200" height="1"/>
            </line>

            <staticText>
                <reportElement x="301" y="520" width="200" height="20"/>
                <textElement textAlignment="Center">
                    <font isBold="true"/>
                </textElement>
                <text><![CDATA[Director Académico]]></text>
            </staticText>

        </band>
    </title>
</jasperReport>