<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="Reporte_Estadistico"
              language="java"
              pageWidth="595"
              pageHeight="842"
              columnWidth="555"
              leftMargin="20"
              rightMargin="20"
              topMargin="20"
              bottomMargin="20">
    <parameter name="TITULO" class="java.lang.String"/>
    <parameter name="NUMEROPERSONAS" class="java.lang.String"/>
    <queryString><![CDATA[]]></queryString>
    <field name="label" class="java.lang.String"/>
    <field name="valor" class="java.lang.Double"/>
    <title>
        <band height="50" splitType="Stretch">
            <textField isBlankWhenNull="true">
                <reportElement x="0" y="5" width="555" height="40"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="16" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{TITULO}]]></textFieldExpression>
            </textField>
        </band>
    </title>
    <columnHeader>
        <band height="36" splitType="Stretch">
            <staticText>
                <reportElement x="0" y="8" width="220" height="24"/>
                <textElement verticalAlignment="Middle">
                    <font isBold="true"/>
                </textElement>
                <text><![CDATA[Total personas registradas:]]></text>
            </staticText>
            <textField isBlankWhenNull="true">
                <reportElement x="225" y="8" width="120" height="24"/>
                <textElement verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$P{NUMEROPERSONAS}]]></textFieldExpression>
            </textField>
        </band>
    </columnHeader>
    <detail>
        <band height="22" splitType="Stretch">
            <textField isStretchWithOverflow="true" isBlankWhenNull="true">
                <reportElement x="0" y="0" width="260" height="20"/>
                <textFieldExpression><![CDATA[$F{label}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="270" y="0" width="120" height="20"/>
                <textFieldExpression><![CDATA[$F{valor} != null ? String.valueOf($F{valor}.intValue()) : "0"]]></textFieldExpression>
            </textField>
        </band>
    </detail>
    <columnFooter>
        <band height="8"/>
    </columnFooter>
    <pageFooter>
        <band height="20"/>
    </pageFooter>
    <summary>
        <band height="310" splitType="Stretch">
            <barChart>
                <chart evaluationTime="Report">
                    <reportElement x="52" y="10" width="450" height="280"/>
                    <chartTitle>
                        <titleExpression><![CDATA["Personas por género"]]></titleExpression>
                    </chartTitle>
                    <chartLegend/>
                </chart>
                <categoryDataset>
                    <categorySeries>
                        <seriesExpression><![CDATA["Género"]]></seriesExpression>
                        <categoryExpression><![CDATA[$F{label}]]></categoryExpression>
                        <valueExpression><![CDATA[$F{valor}]]></valueExpression>
                    </categorySeries>
                </categoryDataset>
                <barPlot>
                    <plot/>
                    <itemLabel/>
                </barPlot>
            </barChart>
        </band>
    </summary>
</jasperReport>
